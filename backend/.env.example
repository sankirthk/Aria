PORT=8000
NODE_ENV=development

# PostgreSQL
DATABASE_URL="postgresql://postgres:password@localhost:5432/kyron_medical"

# Better Auth
BETTER_AUTH_SECRET="replace-with-64-char-secret"
BETTER_AUTH_URL="http://localhost:8000"

# OpenAI
OPENAI_API_KEY="sk-..."

# Vapi
VAPI_API_KEY="..."
VAPI_PHONE_NUMBER_ID="..."
VAPI_ASSISTANT_ID="..."
VAPI_WEBHOOK_SECRET="..."
VAPI_CREDENTIALS_ID="..."

# SMTP (Gmail)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=465
SMTP_USER="..."
SMTP_PASS="..."

# CORS
ALLOWED_ORIGIN="http://localhost:3000"

# Field Encryption — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
FIELD_ENCRYPTION_KEY="k1.aesgcm256.replace-with-base64url-32-bytes"

# Logging
LOG_LEVEL=debug
LOG_TO_FILE=true
LOG_DIR="./logs"
